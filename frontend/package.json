{
  "name": "cfdi-suite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:api": "cd .. && python3 -m uvicorn backend.app.main:app --host 0.0.0.0 --port 8000",
    "test:api": "cd .. && python3 -m pytest backend/tests/ -q",
    "test:coverage": "cd .. && python3 -m pytest backend/tests/ --cov=backend.app --cov-report=term-missing -q",
    "lint:api": "cd .. && python3 -m ruff check backend/app/",
    "build": "vite build",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "benchmark:current-ts": "node --import tsx src/cfdi/benchmark/runBenchmark.ts --engine=current-ts",
    "benchmark:current-ts:json": "node --import tsx src/cfdi/benchmark/runBenchmark.ts --engine=current-ts --format=json",
    "benchmark:python-satcfdi": "node --import tsx src/cfdi/benchmark/runBenchmark.ts --engine=python-satcfdi",
    "benchmark:python-satcfdi:json": "node --import tsx src/cfdi/benchmark/runBenchmark.ts --engine=python-satcfdi --format=json"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@google/genai": "^1.29.0",
    "@headlessui/react": "^2.2.10",
    "@tailwindcss/vite": "^4.1.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "fast-xml-parser": "^5.5.9",
    "jszip": "^3.10.1",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "happy-dom": "^20.8.8",
    "jsdom": "^29.0.1",
    "playwright": "^1.60.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0",
    "vitest": "^4.1.1"
  }
}
